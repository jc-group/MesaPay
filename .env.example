# MesaPay environment template
# Copy to .env.dev or .env.prod and adjust values.

# PostgreSQL (Docker)
POSTGRES_DB=mesapay
POSTGRES_USER=mesapay_user
POSTGRES_PASSWORD=change_me

# SQLAlchemy connection string
# Docker Compose service name: db
DATABASE_URL=postgresql://mesapay_user:change_me@db:5432/mesapay

# Ports
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Frontend -> Backend
# Use localhost when running frontend outside Docker.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
